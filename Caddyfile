:80 {
	root * /srv/perry-ui

	# Registry API — CORS headers for CLI access
	handle /r/* {
		header Access-Control-Allow-Origin "*"
		header Access-Control-Allow-Methods "GET, OPTIONS"
		header Content-Type "application/json"
		file_server
	}

	# Static component/theme/block files
	handle /r/components/* {
		header Access-Control-Allow-Origin "*"
		file_server
	}

	# Fallback
	handle {
		file_server
	}
}
