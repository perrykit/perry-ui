{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@perry-ui/core": ["./packages/core/src"],
      "@perry-ui/core/*": ["./packages/core/src/*"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
