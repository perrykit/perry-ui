{
  "name": "@perrykit/ui",
  "version": "0.1.2",
  "description": "CLI for Perry UI - shadcn-style component registry for Perry native TypeScript apps",
  "bin": {
    "perry-ui": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outfile dist/cli.js --target bun",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/bun": "^1.1.0"
  },
  "files": [
    "dist/"
  ],
  "keywords": [
    "perry",
    "perry-ui",
    "cli",
    "components",
    "registry"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/perrykit/perry-ui",
    "directory": "packages/cli"
  },
  "homepage": "https://perry-ui.com",
  "publishConfig": {
    "access": "public"
  }
}
